{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Dev (full stack)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "autoPort": true
    },
    {
      "name": "API server (Express)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["nodemon", "server/index.js"],
      "port": 3000
    },
    {
      "name": "Vite client",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:client"],
      "port": 5173,
      "autoPort": true
    }
  ]
}
