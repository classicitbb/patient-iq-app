{
  "name": "patient-smart-app",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon server/index.js",
    "dev:staging": "node --env-file=.env.staging node_modules/.bin/nodemon server/index.js",
    "dev:client": "vite client --config client/vite.config.js",
    "build": "vite build client --mode production",
    "build:staging": "vite build client --mode staging",
    "start": "node server/index.js",
    "start:staging": "node --env-file=.env.staging server/index.js",
    "seed": "node scripts/seed.js",
    "seed:pricesmart": "node scripts/seed-pricesmart.js",
    "seed:reset": "node scripts/seed-reset.js",
    "migrate": "node scripts/migrate.js",
    "create-tenant": "node scripts/create-tenant.js",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:db:reset": "supabase db reset",
    "supabase:migration:new": "supabase migration new"
  },
  "dependencies": {
    "@vercel/analytics": "^1.0.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@vitejs/plugin-legacy": "^8.0.1",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0",
    "supabase": "^2.98.2",
    "vite": "^8.0.12"
  }
}
